<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icon foreground: stylised "H" play-mark in HubPlay amber.
     The 108×108 viewport with a 72×72 safe zone is the Android adaptive
     icon spec — anything outside the safe zone gets clipped by the
     launcher's mask. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Two vertical bars + a connecting beam = the H -->
    <path
        android:fillColor="#FFB300"
        android:pathData="M36,30 L36,78 L44,78 L44,58 L64,58 L64,78 L72,78 L72,30 L64,30 L64,50 L44,50 L44,30 Z" />

    <!-- Triangle play-glyph nestled in the right bowl, scaled down -->
    <path
        android:fillColor="#0B0B0E"
        android:pathData="M67,52 L77,58 L67,64 Z" />
</vector>
