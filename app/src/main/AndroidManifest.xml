<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Streaming + auth need network. INTERNET is granted automatically
         on every Android version; ACCESS_NETWORK_STATE lets us avoid
         starting playback when offline. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground service for background audio + ongoing media playback
         (Media3 MediaSessionService). Declared up front because runtime
         start of the service from a non-foreground context fails on
         Android 14+ without this permission. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Wake lock so playback doesn't pause when the screen times out
         (audio-only) or for download workers later. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Make the app installable on Android TV / Fire TV. The leanback
         feature is "not required" so the same APK still installs on
         phones and tablets that lack a TV input. -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />
    <!-- Touchscreen "not required" so phone-less TV form factors don't
         filter the listing out. -->
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <application
        android:name=".HubplayApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HubPlay"
        android:usesCleartextTraffic="false"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.HubPlay.Splash">
            <!-- Phone / tablet launcher entry. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Android TV launcher entry — same Activity, different
                 category so the app shows up in the TV home carousel
                 alongside the phone/tablet shortcut. A future iteration
                 can ship a TV-specific Activity if the focus model
                 needs to diverge. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
